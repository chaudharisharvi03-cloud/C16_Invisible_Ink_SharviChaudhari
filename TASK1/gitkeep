def embed_message(pixel_values,secret_message):
    lists=[]
    for i in range(len(secret_message)):
        bineq=bin(pixel_values[i])
        answer=int(bineq[2:])
        if secret_message[i]==0:
            ans=answer & ~1
            lists.append(int(str(ans),2))
        elif secret_message[i]==1:
            ans=answer | 1
            lists.append(int(str(ans),2))
    print(lists)
pixel_values=[int(x) for x in input("enter the pixel values:").split()]
secret_message=[int(x) for x in input("enter the secret message:").split()]
embed_message(pixel_values,secret_message)

