def embed_bit(pixel_value,secret_bit):
    #secret_bit is only 0 or 1
    #pixel_value can be any integer
    binary=bin(pixel_value)
    answer=int(binary[2:])
    if secret_bit==0:
        ans=answer & ~1
        print(int(str(ans),2))
    elif secret_bit==1:
        ans=answer | 1
        print(int(str(ans),2))
pixel_value=int(input("enter a number"))
secret_bit=int(input("enter either 1 or 0"))
embed_bit(pixel_value,secret_bit)




